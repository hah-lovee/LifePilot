# --- Postgres ---
POSTGRES_USER=life_pilot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=life_pilot

# --- Backend (mounted as backend/.env via env_file) ---
DATABASE_URL=postgresql+psycopg://life_pilot:change-me@postgres:5432/life_pilot
SECRET_KEY=generate-a-long-random-string
REGISTRATION_CODE=pick-a-private-invite-code
CORS_ORIGINS=["https://your-domain.example"]
# Investments integration (trading-keys-api), see docs/ADMIN_GUIDE.md.
# INVESTMENTS_API_URL should point at the trading-keys-api container's
# internal docker network address (e.g. http://trading-api:8000), not
# localhost — they must share a docker network for this to resolve.
INVESTMENTS_API_URL=http://trading-api:8000
INVESTMENTS_API_KEY=copy-the-API_KEY-line-from-trading-keys-api/data/init/tokens.env

# --- Frontend ---
# Leave empty: every frontend request already starts with /api itself
# (see frontend/src/lib/api.ts), so this is just the base to prefix it with.
# The reverse proxy (Caddy/nginx) routes /api/* to the backend container.
NEXT_PUBLIC_API_URL=

# --- Reverse proxy ---
DOMAIN=your-domain.example
